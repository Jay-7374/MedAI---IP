# Copy this file to .env and fill in your own values
# DO NOT commit the actual .env file

# Supabase PostgreSQL connection string
# ⚠️  Use the CONNECTION POOLER URL (not the direct URL) for IPv4 compatibility.
#     Direct URL (db.xxx.supabase.co:5432) is IPv6-only and fails on most home/office networks.
#     Go to: Supabase Dashboard → Settings → Database → Connection Pooling → Mode: Session
#     The pooler URL looks like:
DATABASE_URL=postgresql://postgres.<your_project_ref>:<your_password>@aws-0-<region>.pooler.supabase.com:6543/postgres


# Groq LLM API key (https://console.groq.com)
GROQ_API_KEY=gsk_...

# ElevenLabs API Key for TTS (https://elevenlabs.io)
ELEVENLABS_API_KEY=sk_...

# JWT Authentication Config
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Twilio credentials (https://console.twilio.com)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Default outbound call target
DEFAULT_PATIENT_PHONE=+91...

# Public base URL for Twilio webhooks (use ngrok locally)
PUBLIC_BASE_URL=https://<your-ngrok-or-render-url>

# CORS — comma-separated list of allowed frontend origins
# Example: https://your-app.vercel.app,http://localhost:5173
ALLOWED_ORIGIN=http://localhost:5173,http://localhost:5174
